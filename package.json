{
  "name": "plaintext-gg",
  "private": true,
  "type": "module",
  "scripts": {
    "preinstall": "node -e \"if(!process.env.npm_execpath?.includes('pnpm')){console.error('Use pnpm, not npm.');process.exit(1)}\"",
    "postinstall": "playwright install chromium",
    "dev": "node server.js",
    "test": "pnpm run test:unit && pnpm run test:e2e",
    "test:unit": "node --test tests/editor.test.js",
    "test:e2e": "pnpm exec playwright test",
    "typecheck": "tsc -p jsconfig.json --noEmit && tsc -p jsconfig.sw.json --noEmit && tsc -p jsconfig.server.json --noEmit",
    "check": "pnpm run typecheck && pnpm test",
    "deploy": "node scripts/deploy-bunny-storage.mjs"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^24.12.2",
    "typescript": "^6.0.0"
  }
}
