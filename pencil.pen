                {
                  "type": "text",
                  "id": "a1oge",
                  "name": "body2",
                  "fill": "$text-primary",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "plaintext.gg stores everything in your browser's localStorage.\n\nno cookies. no analytics. no tracking.\nno accounts. no server. no database.\n\nyour text never leaves your device.\n\nthe entire site is static HTML, CSS, and JavaScript.\nyou can verify this yourself — view source.\n\nwe believe the best privacy policy\nis not needing one at all.",
                  "lineHeight": 1.7,
                  "fontFamily": "JetBrains Mono",
                  "fontSize": 14,
                  "fontWeight": "normal"
                }
              ]
